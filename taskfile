#!/bin/bash

if [[ $* == *-debug* ]]; then
    set -x
fi

BINNAME="envset"
BINPATH="cmd/envset"
VERSION_FILE="./.version"
PROJECT="$(awk 'match($0, /module (.*)/) {print substr($2, RSTART, RLENGTH)}' go.mod)"
ENTRYPOINT="cmd/envset/main.go"
CODE_EDITOR=ci
GO_VERSION=go1.17.8

# If we have a .taskenv file load it as source
# we can override the previous set of variables
if [ -f .taskenv ]; then
    # shellcheck disable=SC1091
    source .taskenv
fi

# This will make all scripts available in the ./src/bin directory
PATH=./src/bin:$PATH

GO_TOOLCHAIN="${GO_TOOLCHAIN:-local}"
GO_GOLANGCI_LINT_VERSION="${GO_GOLANGCI_LINT_VERSION:-v2.11.3}"
GO_GOLANGCI_LINT_VERSION_FILE="${GO_GOLANGCI_LINT_VERSION_FILE:-.golangci-lint-version}"
GO_GOVULNCHECK_VERSION="${GO_GOVULNCHECK_VERSION:-v1.1.4}"
GO_GOSEC_VERSION="${GO_GOSEC_VERSION:-v2.25.0}"
GO_QUALITY_GOCACHE="${GO_QUALITY_GOCACHE:-$(pwd)/.tmp/go-cache}"
GO_QUALITY_GOTMPDIR="${GO_QUALITY_GOTMPDIR:-$(pwd)/.tmp/go-tmp}"
GO_LINT_NEW_FROM_REV="${GO_LINT_NEW_FROM_REV:-origin/master}"

function _go:bin {
    if command -v go >/dev/null 2>&1; then
        command -v go
        return 0
    fi

    echo "go binary not found in PATH" >&2
    return 1
}

function _go:quality:prepare_env {
    export GOCACHE="${GOCACHE:-${GO_QUALITY_GOCACHE}}"
    export GOTMPDIR="${GOTMPDIR:-${GO_QUALITY_GOTMPDIR}}"
    mkdir -p "${GOCACHE}" "${GOTMPDIR}"
}

function _go:golangci_lint_version {
    if [ -f "${GO_GOLANGCI_LINT_VERSION_FILE}" ]; then
        awk 'NF { print $1; exit }' "${GO_GOLANGCI_LINT_VERSION_FILE}"
        return 0
    fi

    printf '%s\n' "${GO_GOLANGCI_LINT_VERSION}"
}

function _go:tool_bin_dir {
    local go_bin
    local gobin
    local gopath

    go_bin=$(_go:bin) || return 1
    gobin="$("${go_bin}" env GOBIN)"
    if [ -n "${gobin}" ]; then
        printf '%s\n' "${gobin}"
        return 0
    fi

    gopath="$("${go_bin}" env GOPATH)"
    if [ -n "${gopath}" ]; then
        printf '%s\n' "${gopath%/}/bin"
        return 0
    fi

    echo "unable to resolve Go tool bin directory" >&2
    return 1
}

function _go:tool:path {
    local name=$1
    local bin_dir

    if command -v "${name}" >/dev/null 2>&1; then
        command -v "${name}"
        return 0
    fi

    bin_dir=$(_go:tool_bin_dir) || return 1
    if [ -x "${bin_dir}/${name}" ]; then
        printf '%s\n' "${bin_dir}/${name}"
        return 0
    fi

    return 1
}

function _go:tool:install {
    local name=$1
    local target=$2
    local go_bin

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    echo "Installing ${name} (${target})"
    GOTOOLCHAIN="${GO_TOOLCHAIN}" "${go_bin}" install "${target}" || return 1
    _go:tool:path "${name}" || return 1
}

function _go:tool:ensure {
    local name=$1
    local target=$2
    local tool_path

    if tool_path=$(_go:tool:path "${name}" 2>/dev/null); then
        printf '%s\n' "${tool_path}"
        return 0
    fi

    _go:tool:install "${name}" "${target}"
}

function _go:packages {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    if [ "$#" -gt 0 ]; then
        patterns=("$@")
    else
        patterns=("./...")
    fi

    "${go_bin}" list "${patterns[@]}"
}

function _go:files {
    find . -type f -name '*.go' \
        -not -path './.git/*' \
        -not -path './.gocache/*' \
        -not -path './.tmp/*' \
        -not -path './node_modules/*' \
        | sort
}

function _go:lint:patterns {
    if [ "$#" -gt 0 ]; then
        printf '%s\n' "$@"
        return 0
    fi

    printf '%s\n' "./..."
}

